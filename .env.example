# Copy this file to .env and fill in your values.
#   cp .env.example .env

# OpenRouter API key for the Phase 1.5 candidate filter.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Free model used for classification (keep the ':free' suffix to stay free).
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Requests-per-minute ceiling for the filter. Free tier hard cap is 20;
# 18 leaves headroom.
OPENROUTER_RPM=18
